# Gateway Service Configuration
# Copy this file to .env and modify as needed

# ============================================
# Server Configuration
# ============================================
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
# Graceful shutdown timeout in seconds
SERVER_SHUTDOWN_TIMEOUT=30

# ============================================
# Authentication Configuration
# ============================================
# Development Mode (NEVER enable in production)
# Set to true to bypass authentication for development/testing
AUTH_DEVELOPMENT_MODE=false

# Development Client ID (only used when AUTH_DEVELOPMENT_MODE=true)
# Customize the mock client ID used in development mode
AUTH_DEV_CLIENT_ID=dev-client-123

# Performance Monitoring
# Slow operation threshold in milliseconds
# Operations taking longer than this will be logged as warnings
# Default: 10ms (suitable for mock data, increase for database operations)
AUTH_SLOW_THRESHOLD_MS=10

# ============================================
# Logging Configuration
# ============================================
# Log level: trace, debug, info, warn, error
LOG_LEVEL=info
# Enable JSON structured logging (recommended for production)
LOG_JSON=false

# ============================================
# External Service URLs (gRPC)
# ============================================
# Router Service - AI model routing and selection
ROUTER_SERVICE_URL=http://localhost:50051

# Memory Service - Conversation context management
MEMORY_SERVICE_URL=http://localhost:50052

# Rewrite Service - Request rewriting and transformation
REWRITE_SERVICE_URL=http://localhost:50053

# Validation Service - Request validation
VALIDATION_SERVICE_URL=http://localhost:50054

# gRPC connection timeout in milliseconds
GRPC_CONNECTION_TIMEOUT_MS=5000

# gRPC request timeout in milliseconds
GRPC_REQUEST_TIMEOUT_MS=30000

# ============================================
# LLM Vendor API Keys (Executor Layer)
# ============================================
# OpenAI API Key (required for OpenAI models)
OPENAI_API_KEY=your-openai-api-key-here

# OpenAI Base URL (optional, default: https://api.openai.com/v1)
# Useful for proxies or custom endpoints
# OPENAI_BASE_URL=https://api.openai.com/v1

# OpenAI Request Timeout (optional, default: 30000ms)
# OPENAI_TIMEOUT_MS=30000

# Anthropic API Key (future support)
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Executor Layer Configuration
# Request timeout in milliseconds (default: 30000)
EXECUTOR_TIMEOUT_MS=30000

# Maximum number of retries for failed requests (default: 3)
EXECUTOR_MAX_RETRIES=3

# ============================================
# Production Settings
# ============================================
# AUTH_DEVELOPMENT_MODE should always be false or unset in production
# LOG_JSON should be true in production for structured logging
# Adjust timeouts based on your infrastructure requirements
# NEVER commit real API keys to version control
