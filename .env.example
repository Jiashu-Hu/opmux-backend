# Authentication Configuration
# Copy this file to .env and modify as needed

# Development Mode (NEVER enable in production)
# Set to true to bypass authentication for development/testing
AUTH_DEVELOPMENT_MODE=false

# Development Client ID (only used when AUTH_DEVELOPMENT_MODE=true)
# Customize the mock client ID used in development mode
AUTH_DEV_CLIENT_ID=dev-client-123

# Production Settings
# AUTH_DEVELOPMENT_MODE should always be false or unset in production
